# Session secret for nuxt-auth-utils (required, min 32 characters)
# Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=your-super-secret-session-password-at-least-32-chars

# PostgreSQL Database Connection
# For local development: Uses PGlite (embedded) if not set
# For production: Set your PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@hostname:5432/database

# Nuxt Hub credentials (for production)
# NUXT_HUB_PROJECT_KEY=your-project-key
# NUXT_HUB_PROJECT_SECRET=your-project-secret

# Optional: Override app name
# NUXT_PUBLIC_APP_NAME=ReportFlow

